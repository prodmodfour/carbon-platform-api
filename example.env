# Safe local defaults for docker-compose.yml.
# Copy this file to .env to override Docker Compose settings locally.
# Do not use these local-only placeholder credentials outside development.

API_IMAGE_NAME=carbon-platform-api
API_IMAGE_TAG=local
API_HOST_PORT=8000

CARBON_API_APP_NAME=carbon-platform-api
CARBON_API_APP_VERSION=0.1.0
CARBON_API_ENVIRONMENT=local
CARBON_API_LOG_LEVEL=INFO
CARBON_API_DOCS_ENABLED=false
CARBON_API_DATABASE_URL=postgresql+asyncpg://carbon_platform_api:local_dev_password@postgres:5432/carbon_platform_api
CARBON_API_REDIS_URL=redis://redis:6379/0
CARBON_API_CARBON_INTENSITY_PROVIDER_BASE_URL=https://carbon-intensity.example.invalid
CARBON_API_CARBON_INTENSITY_PROVIDER_TIMEOUT_SECONDS=2.0
CARBON_API_CARBON_INTENSITY_CACHE_TTL_SECONDS=900

POSTGRES_IMAGE_TAG=16-alpine
POSTGRES_HOST_PORT=5432
POSTGRES_DB=carbon_platform_api
POSTGRES_USER=carbon_platform_api
POSTGRES_PASSWORD=local_dev_password

REDIS_IMAGE_TAG=7-alpine
REDIS_HOST_PORT=6379

PROMETHEUS_IMAGE_TAG=v2.55.1
PROMETHEUS_HOST_PORT=9090

GRAFANA_IMAGE_TAG=11.3.0
GRAFANA_HOST_PORT=3000
GRAFANA_ADMIN_USER=local_admin
GRAFANA_ADMIN_PASSWORD=local_dev_password
